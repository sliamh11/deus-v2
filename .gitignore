# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Warden gate markers (user-local; refreshed by warden agents)
.claude/.plan-reviewed
.claude/.code-reviewed
.claude/.threat-modeled
.claude/.ai-eng-reviewed
.claude/.verified
.claude/.commit-window
# Warden verdict store + audit log (host-local runtime state; recreated on first mark)
.claude/.warden-verdicts.json
.claude/.warden-verdicts.json.lock
.claude/.warden-log
# Admin-merge gate markers (host-local; contain absolute worktree paths)
.claude/.admin-merge-approved
.claude/.admin-merge-standing
.claude/.warden-verdicts.json.bak-*
# Per-worktree gate state (markers + verdict store, namespaced by worktree)
.claude/worktree-markers/
# Co-gate backend verdict markers (user-local; per-role @<backend>)
.claude/.*@*
# Co-gate loop backups (timestamped runtime ephemera)
.claude/.co-gate-loop-*.bak-*
# Plan revise log + scratch plan docs (host-local working notes)
.claude/plan-revise-log.jsonl
.claude/.plan-*.md
# One-time migration nudge flag (host-local)
.claude/.migration-nudged

# Warden config (user-local toggle state and custom instructions)
.claude/wardens/config.json

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/codebase_map.md

# Local data & auth
store/
data/
logs/
# Local experiment scratch space (never shipped)
/experiments/

# Groups - only track base structure and template files
groups/*
!groups/main/
!groups/global/
!groups/linear-dispatch/
groups/main/*
groups/global/*
groups/linear-dispatch/*
!groups/main/CLAUDE.md.template
!groups/global/CLAUDE.md.template
!groups/linear-dispatch/CLAUDE.md.template

# Generated group CLAUDE.md files (local customizations, like .env)
groups/*/CLAUDE.md
!groups/*/CLAUDE.md.template

# Secrets — never commit credentials, tokens, or keys
# RULE: this project is designed to be public — treat every commit as if it will be public
.env
.env.local
.env.*
!.env.example        # allow .env.example (no real values)
*.keys.json
*.credentials.json   # catch any stray credentials file
*.token              # raw token files
*.pem                # TLS/SSH private keys
*.p12
*.pfx
integrations/gcal/credentials.json
integrations/gcal/tokens.json
config.local.json    # local config overrides that may contain secrets
# Open WebUI session signing key (generated by scripts/webui-serve.sh)
.webui_secret_key

# Personal/one-time scripts
scripts/rename-repo.sh
scripts/send-webhook-test.sh

# Rust build artifacts
tui/target/

# Python virtual env
.venv/
__pycache__/
.coverage

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/
.eslintcache

# Skills system (local per-installation state)
.deus/

# Project-local memory vault (alternative to external vault path)
.vault/

# Local-only skills — listed here so they're not staged into container builds
# One skill name per line (e.g., "x-integration"). No paths, just the name.
.local-skills

# Skill local dependencies (each skill manages its own node_modules)
.claude/skills/*/node_modules/
.claude/skills/*/package-lock.json
# Skill host.ts files are local-only (private implementations)
# Community skill templates commit SKILL.md + agent.ts only
.claude/skills/*/host.ts
.claude/skills/*/host.js
.claude/skills/*/scripts/
.claude/skills/*/lib/

# Container build staging (generated by build.sh)
container/skill-agents/*
!container/skill-agents/.gitkeep

# MCP channel packages (local dev artifacts)
packages/*/node_modules/
packages/*/dist/
packages/*/package-lock.json

agents-sdk-docs
.agents/
deus.db

# Eval reports (generated by parity/quality benchmarks)
eval/.report.json
eval/.quality_bench_results*.json
scripts/bench/results/
scripts/bench/rule_following_judge_cache.json
scripts/bench/attention_dilution_pairwise_cache.json
scripts/bench/attention_dilution_recall_cache.json

# Fine-tune artifacts
finetune/data/
finetune/adapters/
finetune/gemma4-tool-fused/
finetune/judge-lora-gemma3n/
# Judge benchmark: real-interaction fixture + run results contain user prompts/responses (PII) — local only
finetune/judge-bench/

# Developer tools (local indexes)
.codegraph/
.understand-anything/

# Private features — local-only code that must never be committed
# Personal integrations, trading logic, account-specific tools, etc.
src/private/

# Architecture Explorer — generated graph data (re-run build.py to regenerate)
tools/architecture-explorer/graph-data.js
